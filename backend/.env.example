# =============================================================================
# Helix.AI Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control - it may contain sensitive information.

# =============================================================================
# LLM API Configuration
# =============================================================================
# At least one LLM provider must be configured (OpenAI or DeepSeek)

# OpenAI API Key (required if using OpenAI)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek API Key (required if using DeepSeek)
# Get your API key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Model overrides for specific agents (optional)
# Format: "openai:model-name" or just "model-name" (will be prefixed with "openai:")
# Defaults shown below
HELIX_TOOLGEN_OPENAI_MODEL=openai:gpt-4o
HELIX_INFRASTRUCTURE_OPENAI_MODEL=openai:gpt-4o
HELIX_INTENT_OPENAI_MODEL=openai:gpt-5.2

# =============================================================================
# AWS Configuration
# =============================================================================

# AWS Region (default: us-east-1)
# Can also use AWS_DEFAULT_REGION
AWS_REGION=us-east-1

# AWS Credentials
# These are typically loaded from ~/.aws/credentials or IAM roles
# If running locally, you may need to set these:
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# =============================================================================
# S3 Configuration
# =============================================================================

# Primary S3 bucket for datasets (default: noricum-ngs-data)
S3_DATASET_BUCKET=noricum-ngs-data

# S3 bucket for scripts (defaults to S3_DATASET_BUCKET if not set)
S3_SCRIPT_BUCKET=

# S3 bucket for frontend/session storage (default: helix-ai-frontend-794270057041-us-west-1)
S3_BUCKET_NAME=helix-ai-frontend-794270057041-us-west-1

# =============================================================================
# EC2 Configuration
# =============================================================================

# Enable EC2 execution (default: false)
# Set to "true" to enable EC2-based tool execution
HELIX_USE_EC2=false

# Pre-existing EC2 instance ID (optional)
# If set, will use this instance instead of creating a new one
HELIX_EC2_INSTANCE_ID=

# EC2 Key Pair Name (required if using EC2)
# The name of your EC2 key pair (not the file path)
HELIX_EC2_KEY_NAME=

# Path to EC2 private key file (required if using EC2)
# Absolute path to your .pem or .ppk private key file
HELIX_EC2_KEY_FILE=

# Auto-create EC2 instance if instance_id not found (default: false)
# Set to "true", "1", "yes", "on", or "auto-create" to enable
HELIX_EC2_AUTO_CREATE=false

# EC2 Instance Type (default: t3.medium)
# Used when auto-creating instances
HELIX_EC2_INSTANCE_TYPE=t3.medium

# Custom AMI ID with bioinformatics tools pre-installed (optional)
# If not set, will use default AMI for the instance type
HELIX_EC2_AMI_ID=

# EC2 Security Group ID (optional)
# Required if auto-creating instances
HELIX_EC2_SECURITY_GROUP_ID=

# EC2 Subnet ID (optional)
# Required if auto-creating instances
HELIX_EC2_SUBNET_ID=

# EC2 IAM Role Name (optional)
# IAM role to attach to EC2 instances for S3 access
HELIX_EC2_IAM_ROLE_NAME=

# =============================================================================
# EMR (Elastic MapReduce) Configuration
# =============================================================================

# EMR Cluster ID (optional)
# If set, will use this existing cluster instead of creating a new one
EMR_CLUSTER_ID=

# EMR Cluster Name (default: helix-ai-fastqc)
# Used when creating new clusters
EMR_CLUSTER_NAME=helix-ai-fastqc

# EMR Instance Type (default: m5.xlarge)
# Instance type for EMR cluster nodes
EMR_INSTANCE_TYPE=m5.xlarge

# EMR Instance Count (default: 3)
# Number of instances in the EMR cluster
EMR_INSTANCE_COUNT=3

# =============================================================================
# Execution Configuration
# =============================================================================

# Async execution threshold in bytes (default: 104857600 = 100MB)
# Files larger than this will be routed to async execution (EMR)
# Can be overridden per-tool in execution_broker.py
HELIX_ASYNC_BYTES_THRESHOLD=104857600

# Enable Infrastructure Decision Agent in ExecutionBroker (default: false)
# When enabled, ExecutionBroker will use the Infrastructure Decision Agent
# for more sophisticated routing decisions
# Note: Tool Generator Agent always uses Infrastructure Decision Agent
HELIX_USE_INFRASTRUCTURE_AGENT=false

# =============================================================================
# Tool Configuration
# =============================================================================

# Comma-separated list of CLI tool candidates to detect (optional)
# If not set, uses default list of common bioinformatics tools
# Example: "samtools,bcftools,bwa,bbmerge.sh"
HELIX_CLI_TOOL_CANDIDATES=

# =============================================================================
# CORS Configuration
# =============================================================================

# CORS allowed origins (comma-separated, default: localhost ports)
# When allow_credentials=True, cannot use "*" - must specify explicit origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5174

# =============================================================================
# Development/Testing Configuration
# =============================================================================

# Mock Mode (default: not set)
# Set to "1" to disable LLM calls and network operations (for testing)
# When enabled, LLM-dependent features will raise RuntimeError
HELIX_MOCK_MODE=

# LangChain Debug/Verbose Logging (default: false)
# Enable verbose logging for LangChain operations
LANGCHAIN_VERBOSE=false
LANGCHAIN_DEBUG=false

# =============================================================================
# Notes
# =============================================================================
# - All boolean values can be: "true", "1", "yes", "on" (case-insensitive)
# - File paths should be absolute paths
# - S3 bucket names should not include "s3://" prefix
# - AWS credentials are typically loaded from ~/.aws/credentials or IAM roles
# - If both OPENAI_API_KEY and DEEPSEEK_API_KEY are set, OpenAI takes precedence
# - EC2 configuration is only used when HELIX_USE_EC2=true
# - EMR configuration is only used for large file operations (>100MB by default)
