# Copy to /etc/helix/helix.env on the EC2 instance (chmod 600).
# sudo cp scripts/ec2/helix.env.example /etc/helix/helix.env && sudo chmod 600 /etc/helix/helix.env

# --- LLM (at least one required) ---
OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# --- Local-only sessions (no S3 session markers) ---
HELIX_LOCAL_SESSIONS_ONLY=1
HELIX_SESSIONS_DIR=/var/lib/helix/sessions

# --- Optional beta limits ---
HELIX_MAX_UPLOAD_MB=10
