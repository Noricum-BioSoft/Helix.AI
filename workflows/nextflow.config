/*
 * Helix.AI — Nextflow base configuration
 *
 * Applies sensible resource limits for local Docker execution (Tier 3a).
 * Override via environment variables or a site-specific nextflow.config.
 */

// Default executor: local (Docker handles containers)
process {
    executor = "local"

    // Default resource caps — individual processes may request less
    cpus   = 2
    memory = "4 GB"
    time   = "2 h"

    // Retry failed tasks once with slightly more memory
    errorStrategy = { task.exitStatus in [104, 134, 137, 139, 143, 247] ? "retry" : "finish" }
    maxRetries    = 1

    withLabel: "process_high" {
        cpus   = 4
        memory = "8 GB"
    }
}

docker {
    enabled    = true
    runOptions = "-u \$(id -u):\$(id -g)"
}

// Resource limits for Tier 3a local execution
params {
    max_cpus   = 8
    max_memory = "16 GB"
    max_time   = "6 h"
}

// Capture pipeline reports in the work directory
timeline { enabled = true  }
report   { enabled = true  }
dag      { enabled = false }  // disable DOT dag to avoid graphviz dependency
